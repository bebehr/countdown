{
  "name": "countdown",
  "version": "1.0.0",
  "private": true,
  "description": "A simple countdown application",
  "keywords": [
    "countdown",
    "timer"
  ],
  "homepage": "https://github.com/bebehr/countdown#readme",
  "bugs": {
    "url": "https://github.com/bebehr/countdown/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bebehr/countdown.git"
  },
  "license": "MIT",
  "author": "bebehr (https://github.com/bebehr)",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "npm run lint:package-json && npm run lint:js && npm run lint:html",
    "lint:html": "npx htmlhint . --ignore \"**/dist/**,**/node_modules/**\"",
    "lint:js": "npx standard",
    "lint:package-json": "npx npm-package-json-lint . && npx sort-package-json --check",
    "preview": "vite preview --base=/countdown/",
    "test": "npm run lint && npm run test:npm",
    "test:npm": "npm audit && npm outdated"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.16.1",
    "bootstrap": "^5.3.8"
  },
  "devDependencies": {
    "htmlhint": "^1.9.2",
    "npm-package-json-lint": "^9.1.0",
    "npm-package-json-lint-config-default": "^8.0.1",
    "sass": "^1.100.0",
    "sort-package-json": "^3.6.1",
    "standard": "^17.1.2",
    "vite": "^8.0.12"
  }
}
